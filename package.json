    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-ecs": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/client-sns": "^3.1030.0",
    "@base-ui/react": "^1.4.0",
    "@turf/turf": "^7.3.5",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "jose": "^6.2.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "^15.1.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "province-city-china": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
