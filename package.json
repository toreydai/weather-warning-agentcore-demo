{
  "name": "weather-warning-agentcore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:init": "npx tsx scripts/init-db.ts",
    "db:fetch": "npx tsx scripts/fetch-weather.ts",
    "db:backfill-observations": "npx tsx scripts/fetch-weather.ts --observations-only",
    "db:fetch-historical": "npx tsx scripts/fetch-historical.ts",
    "db:generate": "drizzle-kit generate --config infra/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config infra/drizzle.config.ts",
    "db:check": "drizzle-kit check --config infra/drizzle.config.ts",
    "db:check-alerts": "npx tsx scripts/check-alerts.ts",
    "db:check-zone-alerts": "npx tsx scripts/check-zone-alerts.ts",
    "db:generate-advice": "npx tsx scripts/generate-advice.ts",
    "db:generate-daily-alert": "npx tsx scripts/generate-daily-alert.ts",
    "db:push-daily-alert": "npx tsx scripts/push-daily-alert.ts",
    "db:archive-daily-alerts-monthly": "npx tsx scripts/archive-daily-alerts-monthly.ts",
    "db:archive-alerts": "npx tsx scripts/archive-alerts.ts",
    "forecast:accuracy": "npx tsx scripts/evaluate-forecast-accuracy.ts",
    "test": "vitest run --config __tests__/vitest.config.ts",
    "test:watch": "vitest --config __tests__/vitest.config.ts",
    "eval": "npx tsx scripts/run-eval.ts",
    "manual:acceptance": "npx tsx scripts/manual-acceptance.ts",
    "smoke": "npx tsx scripts/smoke-test.ts",
    "deploy": "bash infra/sv.sh",
    "deploy:web": "bash infra/sv.sh deploy web",
    "deploy:web:full": "bash infra/sv.sh deploy web-full",
    "deploy:job": "bash infra/sv.sh deploy job",
    "deploy:all": "bash infra/sv.sh deploy all",
    "deploy:smoke": "bash infra/sv.sh smoke",
    "observability": "bash infra/sv.sh observability",
    "rollback": "bash infra/sv.sh rollback",
    "precheck": "npm run db:check && tsc --noEmit && npm run build && npm test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent": "^3.1036.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.750.0",
