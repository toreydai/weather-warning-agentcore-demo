# 数据库
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 认证（必填，启动时校验）
AUTH_SECRET=your-secret-at-least-16-chars

# 密码策略
PASSWORD_EXPIRE_DAYS=90

# Bedrock Knowledge Base
KNOWLEDGE_BASE_ID=your-kb-id
KNOWLEDGE_BASE_BUCKET=your-kb-s3-bucket
KNOWLEDGE_BASE_DATA_SOURCE_ID=your-kb-data-source-id

# AWS
AWS_REGION=us-east-1

# AgentCore Runtime（病虫害走 Runtime 时需要）
USE_AGENTCORE_FARMING=true
FARMING_ADVISOR_FAST_ARN=arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:runtime/NAME
FARMING_ADVISOR_DEEP_ARN=arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:runtime/NAME

# AgentCore Memory（可选，主读聊天历史）
# CHAT_MEMORY_ID=your-memory-id
# CHAT_PG_TRANSCRIPT_MODE=fallback  # fallback|dual|off; fallback=Memory 有效时不写 PG transcript

# 备用 Runtime（当前代码走本地 Converse，ARN 保留备用）
# WEATHER_ANALYST_ARN=
# ALERT_ANALYST_ARN=

# Cookie（HTTPS 上线后设为 true）
# COOKIE_SECURE=true

# CORS / 日志
# CORS_ORIGINS=https://example.com,https://admin.example.com
LOG_LEVEL=info
# RATE_LIMIT_STORE=pg  # 默认 pg; 本地无 DATABASE_URL 时自动回退 memory

# 站点与测试
# APP_BASE_URL=https://example.com
# EVAL_BASE_URL=https://example.com
# SMOKE_BASE_URL=https://example.com
# SMOKE_USERNAME=admin
# SMOKE_PASSWORD=admin123

# 企业微信机器人
# WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# Feature flags
FEATURE_DAILY_ALERT=false
FEATURE_WECOM_PUSH=false
FEATURE_FORECAST_45D=false
FEATURE_KB_UPLOAD=false
